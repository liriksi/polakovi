class Monster:

    def __init__(self, name= "Неизвестная тварь", hp = "100", power = "10"):
        self.name = name
        self.hp = hp
        self.power = power
        print(f"Было здоровья: {self.hp}")

    def mutate(self):
        self.power *= 5
        print(f"{self.name} мутирует! Сила увеличена!")
        print(f"⚔️: {self.power}")

    def rest(self):
        self.hp += 10
        print(f"{self.name} отдыхает в склепе! Здоровье востановленно!")
        print(f"❤️: {self.hp}")

m1 = Monster("Люкан", 15, 90  )
m1.mutate()
m1.rest()
