#решение задач бестиарий часть 3
class Monster:

    def __init__(self, name= "Неизвестная тварь", hp = "100", dmg = "10"):
        self.name = name
        self.hp = hp
        self.dmg = dmg

        print(f"Монстр: {self.name}")
        print(f"HP: {self.hp}")
        print(f"DMG: {self.dmg}")
        print()

name1, hp1, dmg1 = input("Введите данные первого монстра, имя, хп и урон: ").split()
name2, hp2, dmg2 = input("Введите данные второго монстра, имя, хп и урон: ").split()

m1 = Monster(name1, int (hp1), int (dmg1))
m2 = Monster(name2, int (hp2), int (dmg2))

while True:
    print(f"{m1.name} наносит урон {m1.dmg} по {m2.name}")
    print()
    m2.hp -= m1.dmg

    if m2.hp < 0:
        m2.hp = 0
    print(f"у {m2.name} осталось {m2.hp}")
    print()

    if m2.hp == 0:
        print(f"Победил {m1.name}")
        print()
        break

    print(f"{m2.name} наносит урон {m2.dmg} по {m1.name}")
    print()
    m1.hp -= m2.dmg

    if m1.hp < 0:
        m1.hp =0
    print(f"у {m1.name} сталось {m1.hp}")
    print()
    if m1.hp == 0:
        print(f"Победил {m2.name}")
        print()
        break

