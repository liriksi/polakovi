class Inventory:
    def __init__(self, gold):
        self.__gold = gold

    def get_gold(self):
        return f"В кошеле : {self.__gold} проклятых монеток!"

    def change_gold(self, amount):
        new_balance = self.__gold + amount

        if new_balance < 0:
            print("Не достаточно золота для сделокчки!")
        else:
            self.__gold = new_balance

bag = Inventory(50)
print(bag.get_gold())
bag.change_gold(-30)
bag.change_gold(10)
print(bag.get_gold())
bag.change_gold(-100)





