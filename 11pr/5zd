import random

answers = [
    "Бесспорно", "Предрешено", "Никаких сомнений", "Определённо да",
    "Можешь быть уверен в этом", "Мне кажется — да", "Вероятнее всего",
    "Хорошие перспективы", "Знаки говорят — да", "Да",
    "Пока не ясно, попробуй снова", "Спроси позже", "Лучше не рассказывать",
    "Сейчас нельзя предсказать", "Сконцентрируйся и спроси опять",
    "Даже не думай", "Мой ответ — нет", "По моим данным — нет",
    "Перспективы не очень хорошие", "Весьма сомнительно"
]

print("Кукусики, я магический шар, и я знаю ответ на любоооой твой вопрос.")
name = input("Как тебя зовут? ")
print(f"Привет, {name}!")

while True:
    question = input("\nЗадай свой вопрос: ")
    if question.strip() == "":
        print("Ты не задал вопрос. Давай еще раз.")
        continue
    answer = random.choice(answers)
    print(f"Магический шар отвечает: {answer}")

    again = input("Хочешь задать ещё вопрос? (да/нет): ").strip().lower()
    while again not in ["да", "нет"]:
        again = input("Пожалуйста, ответь 'да' или 'нет': ").strip().lower()
    if again == "нет":
        print("Возвращайся, если возникнут вопросы!")
        break
