import random

nested_list = [[random.randint(1, 100) for _ in range(5)] for _ in range(4)]
print("Исходный список:")
for row in nested_list:
    print(row)

max_value = nested_list[0][0]
max_i, max_j = 0, 0

for i in range(len(nested_list)):
    for j in range(len(nested_list[i])):
        if nested_list[i][j] > max_value:
            max_value = nested_list[i][j]
            max_i, max_j = i, j

print(f"\nМаксимальный элемент: {max_value}")
print(f"Позиция: строка {max_i}, столбец {max_j}")
