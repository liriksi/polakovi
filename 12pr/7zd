numbers = [10, 20, 30, 40, 50]
target = int(input("Введите число для поиска: "))

found_index = None
for i in range(len(numbers)):
    if numbers[i] == target:
        found_index = i
        break

if found_index is not None:
    print(f"Индекс числа {target}: {found_index}")
else:
    print("Нет такого числа")
